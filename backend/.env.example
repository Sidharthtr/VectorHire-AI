# ============================================================
# VectorHire AI — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ── REQUIRED ────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── LLM Models ──────────────────────────────────────────────
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_FALLBACK_MODEL=google/gemma-4-31b-it:free
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ── Database ─────────────────────────────────────────────────
# Local dev (SQLite — no Docker needed):
DATABASE_URL=sqlite:///./app/data/vectorhire.db
# Docker / Production (PostgreSQL):
# DATABASE_URL=postgresql://vectorhire:vectorhire@postgres:5432/vectorhire

# ── ChromaDB ─────────────────────────────────────────────────
# Local dev (embedded — no Docker needed):
USE_CHROMADB_SERVER=false
# Docker / Production:
# USE_CHROMADB_SERVER=true
# CHROMADB_HOST=chromadb
# CHROMADB_PORT=8000

# ── Redis ─────────────────────────────────────────────────────
# Local dev (leave empty — app works without Redis):
REDIS_URL=
# Docker / Production:
# REDIS_URL=redis://redis:6379/0
REDIS_TTL_RESUME=604800
REDIS_TTL_SEARCH=3600
REDIS_TTL_LLM=86400

# ── Retrieval ─────────────────────────────────────────────────
RETRIEVAL_MODE=hybrid
DEFAULT_TOP_K=10

# ── App ───────────────────────────────────────────────────────
APP_NAME=VectorHire AI
APP_VERSION=0.1.0
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Job Ingestion APIs (optional) ─────────────────────────────
# Arbeitnow: no key needed
# Adzuna: register free at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_API_KEY=
